#include <Wire.h>
#include <Adafruit_Sensor.h>
#include <Adafruit_BME680.h>

// ==========================================
// 1. PIN DEFINITIONS & GLOBALS
// ==========================================
const int MIC_PIN = A0;      
const int CURRENT_PIN = A1;  
const int CO_PIN = A2;       

Adafruit_BME680 bme; 
const float mV_PER_STEP = 3300.0 / 4095.0; 

// --- TIMERS ---
unsigned long lastCurrentSampleTime = 0;
unsigned long lastMicSampleTime = 0;
unsigned long lastMicCalcTime = 0;
unsigned long lastUploadTime = 0;

// --- CURRENT VARIABLES ---
int currentSampleCount = 0;
float currentSum = 0;

// ARRAYS to hold the history
float currentHistory[10]; 
int currentHistoryIndex = 0;

// --- MIC VARIABLES ---
long micSampleCount = 0;
double micSum = 0;
double micSumOfSquares = 0;

// ARRAYS to hold the history
float micHistory[2];
int micHistoryIndex = 0;

// ==========================================
// 2. INITIALIZATION
// ==========================================
void setup() {
  Serial.begin(115200);
  while (!Serial); 
  
  Serial.println("--- Starting Array-Based IoT Node ---");

  pinMode(MIC_PIN, INPUT);
  pinMode(CURRENT_PIN, INPUT);
  pinMode(CO_PIN, INPUT);

  if (!bme.begin()) {
    Serial.println("BME680 not found, check wiring!");
    while (1); 
  }
  
  bme.setTemperatureOversampling(BME680_OS_8X);
  bme.setHumidityOversampling(BME680_OS_2X);
  bme.setPressureOversampling(BME680_OS_4X);
  bme.setIIRFilterSize(BME680_FILTER_SIZE_3);
}

// ==========================================
// 3. MAIN LOOP
// ==========================================
void loop() {
  unsigned long currentMillis = millis();

  // ---------------------------------------------------------
  // TIMER 1: CURRENT SENSOR (1 sample every 200ms)
  // ---------------------------------------------------------
  if (currentMillis - lastCurrentSampleTime >= 200) {
    int currentADC = analogRead(CURRENT_PIN);
    currentSum += (currentADC * mV_PER_STEP);
    currentSampleCount++;
    lastCurrentSampleTime = currentMillis;

    // At 10 samples (2 seconds), save to the Array
    if (currentSampleCount >= 10) {
      if (currentHistoryIndex < 10) {
        currentHistory[currentHistoryIndex] = currentSum / 10.0;
        currentHistoryIndex++;
      }
      currentSum = 0;
      currentSampleCount = 0;
    }
  }

  // ---------------------------------------------------------
  // TIMER 2: MICROPHONE SAMPLING (500Hz)
  // ---------------------------------------------------------
  if (currentMillis - lastMicSampleTime >= 2) {
    int micADC = analogRead(MIC_PIN);
    micSum += micADC;
    micSumOfSquares += ((double)micADC * micADC);
    micSampleCount++;
    lastMicSampleTime = currentMillis;
  }

  // ---------------------------------------------------------
  // TIMER 3: MICROPHONE RMS CALCULATION (Every 10 seconds)
  // ---------------------------------------------------------
  if (currentMillis - lastMicCalcTime >= 10000) {
    if (micSampleCount > 0 && micHistoryIndex < 2) {
      double mean = micSum / micSampleCount;
      double meanOfSquares = micSumOfSquares / micSampleCount;
      double variance = meanOfSquares - (mean * mean);
      if (variance < 0) variance = 0; 
      
      micHistory[micHistoryIndex] = sqrt(variance) * mV_PER_STEP;
      micHistoryIndex++;
    }

    micSum = 0;
    micSumOfSquares = 0;
    micSampleCount = 0;
    lastMicCalcTime = currentMillis;
  }

  // ---------------------------------------------------------
  // TIMER 4: UPLOAD / PRINT (Triggered every 20 seconds)
  // ---------------------------------------------------------
  if (currentMillis - lastUploadTime >= 20000) {
    
    bme.performReading(); 
    int co_raw = analogRead(CO_PIN);

    Serial.println("");
    Serial.println("===== 20-SECOND DATA PAYLOAD =====");
    Serial.print("Temperature:  "); Serial.print(bme.temperature); Serial.println(" *C");
    Serial.print("Humidity:     "); Serial.print(bme.humidity); Serial.println(" %");
    Serial.print("Pressure:     "); Serial.print(bme.pressure / 100.0); Serial.println(" hPa");
    Serial.print("CO Raw Level: "); Serial.println(co_raw);
    
    // Print the entire Current Array
    Serial.print("Current History (mA): [");
    for (int i = 0; i < currentHistoryIndex; i++) {
      Serial.print(currentHistory[i]);
      if (i < currentHistoryIndex - 1) Serial.print(", ");
    }
    Serial.println("]");

    // Print the entire Audio Array
    Serial.print("Audio RMS History (mV): [");
    for (int i = 0; i < micHistoryIndex; i++) {
      Serial.print(micHistory[i]);
      if (i < micHistoryIndex - 1) Serial.print(", ");
    }
    Serial.println("]");
    Serial.println("==================================");

    // Reset the array indices for the next 20 seconds
    currentHistoryIndex = 0;
    micHistoryIndex = 0;
    
    lastUploadTime = currentMillis;
  }
}
