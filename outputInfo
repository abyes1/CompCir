#include <Wire.h>
#include <Adafruit_Sensor.h>
#include <Adafruit_BME680.h>

// ==========================================
// 1. PIN DEFINITIONS
// ==========================================
const int MIC_PIN = A0;      // SPW2430 Microphone
const int CURRENT_PIN = A1;  // INA169 Current Sensor
const int CO_PIN = A2;       // Analog CO Sensor (via Voltage Divider)

// ==========================================
// 2. GLOBAL OBJECTS & CONSTANTS
// ==========================================
Adafruit_BME680 bme; 

const float mV_PER_STEP = 3300.0 / 4095.0; 
const unsigned long sampleWindow = 10000; // 10 seconds in milliseconds

// Variables for our continuous sampling bucket
unsigned long startMillis = 0;

// Mic variables
double sumOfSquares = 0;
double sum = 0;
long micSampleCount = 0;

// Current variables
float currentSum = 0;
long currentSampleCount = 0;

// ==========================================
// 3. INITIALIZATION (Runs Once)
// ==========================================
void setup() {
  Serial.begin(115200);
  while (!Serial); 
  
  Serial.println("--- Starting IoT Sensor Node ---");

  pinMode(MIC_PIN, INPUT);
  pinMode(CURRENT_PIN, INPUT);
  pinMode(CO_PIN, INPUT);

  if (!bme.begin()) {
    Serial.println("Could not find a valid BME680 sensor, check wiring!");
    while (1); 
  }
  
  bme.setTemperatureOversampling(BME680_OS_8X);
  bme.setHumidityOversampling(BME680_OS_2X);
  bme.setPressureOversampling(BME680_OS_4X);
  bme.setIIRFilterSize(BME680_FILTER_SIZE_3);
  
  Serial.println("Hardware Initialization Complete.");
  Serial.println("Starting 10-second data gathering cycles...");
  Serial.println("--------------------------------");
}

// ==========================================
// 4. MAIN LOOP (Runs Continuously)
// ==========================================
void loop() {
  // --- A. RAPID SAMPLING ---
  // 1. Sample Microphone
  int micADC = analogRead(MIC_PIN);
  sum += micADC;
  sumOfSquares += ((double)micADC * micADC);
  micSampleCount++;

  // 2. Sample Current (1mV from sensor = 1mA of current)
  int currentADC = analogRead(CURRENT_PIN);
  float voltage_mV = currentADC * mV_PER_STEP;
  currentSum += voltage_mV; 
  currentSampleCount++;

  // --- B. 10-SECOND CHECK & PRINT ---
  if (millis() - startMillis >= sampleWindow) {
    
    // 1. Calculate Mic RMS (Variance Formula)
    double mean = sum / micSampleCount;
    double meanOfSquares = sumOfSquares / micSampleCount;
    double variance = meanOfSquares - (mean * mean);
    if (variance < 0) variance = 0; 
    float rms_mV = sqrt(variance) * mV_PER_STEP;

    // 2. Calculate Average Current
    float avgCurrent_mA = currentSum / currentSampleCount;

    // 3. Read CO Sensor (Raw analog value for now)
    int co_raw = analogRead(CO_PIN);

    // 4. Read BME680 Digital Sensor
    bme.performReading(); // Commands the sensor to take a new measurement

    // 5. Print out the Grand Total
    Serial.println("");
    Serial.println("===== NEW READING INTERVAL =====");
    Serial.print("Temperature:  "); Serial.print(bme.temperature); Serial.println(" *C");
    Serial.print("Humidity:     "); Serial.print(bme.humidity); Serial.println(" %");
    Serial.print("Pressure:     "); Serial.print(bme.pressure / 100.0); Serial.println(" hPa");
    Serial.print("Avg 5V Draw:  "); Serial.print(avgCurrent_mA); Serial.println(" mA");
    Serial.print("CO Raw Level: "); Serial.println(co_raw);   
    Serial.print("Sound RMS:    "); Serial.print(rms_mV); Serial.println(" mV");
    Serial.println("================================");

    // 6. Empty the bucket for the next 10 seconds
    sum = 0;
    sumOfSquares = 0;
    micSampleCount = 0;
    currentSum = 0;
    currentSampleCount = 0;
    
    // Reset the clock for the next cycle
    startMillis = millis(); 
  }

  // A tiny 1-millisecond delay keeps the analog-to-digital converter stable
  delay(1); 
}#include <Wire.h>
